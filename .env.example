# Required: Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=123456:replace_me

# Required: authorized Telegram chat IDs (comma-separated)
# Example: one private chat id
TELEGRAM_ALLOWED_CHAT_IDS=123456789

# Optional
TELEGRAM_POLL_TIMEOUT_SECONDS=25
TELEGRAM_POLL_BACKOFF_MS=2000
APPROVAL_TIMEOUT_MS=300000
MESSAGE_RATE_LIMIT_PER_MINUTE=10
MAX_THREAD_LIST=8
APP_SERVER_REQUEST_TIMEOUT_MS=60000
TURN_TIMEOUT_MS=1200000
MESSAGE_DEDUP_RETENTION_MS=604800000

# Codex app-server settings
CODEX_BIN=codex
CODEX_FALLBACK_MODEL=gpt-5.2-codex

# SQLite storage path
BRIDGE_DB_PATH=./data/codex_remote_bridge.db
